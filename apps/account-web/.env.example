NODE_ENV=development
APP_ENV=development
NEXT_PUBLIC_APP_NAME=NetMetric-account-web
NEXT_PUBLIC_API_BASE_URL=http://localhost:5030
NEXT_PUBLIC_APP_ORIGIN=http://localhost:7004
NEXT_PUBLIC_ACCOUNT_URL=http://localhost:7004
NEXT_PUBLIC_AUTH_URL=http://localhost:7002
# Production/staging: set to shared parent domain (example: .netmetric.net) for nm_locale subdomain sharing.
# Development/local: keep empty so Domain attribute is not set (localhost/127.0.0.1/::1 compatibility).
NEXT_PUBLIC_NETMETRIC_COOKIE_DOMAIN=
ACCOUNT_API_BASE_URL=http://localhost:5030
ACCOUNT_ACCESS_COOKIE_NAME=__Secure-netmetric-access
