NODE_ENV=development
APP_ENV=development
NEXT_PUBLIC_APP_NAME=NetMetric-auth-web
NEXT_PUBLIC_API_GATEWAY_BASE_URL=http://localhost:5030
NEXT_PUBLIC_APP_ORIGIN=http://localhost:7002
NEXT_PUBLIC_ACCOUNT_URL=http://localhost:7004
NEXT_PUBLIC_AUTH_ALLOWED_RETURN_ORIGINS=http://localhost:7004,http://localhost:7005,http://localhost:7006
# Production/staging: set to shared parent domain (example: .netmetric.net) for netmetric-locale/netmetric-theme sharing.
# Development/local: keep empty so Domain attribute is not set.
NEXT_PUBLIC_NETMETRIC_COOKIE_DOMAIN=
