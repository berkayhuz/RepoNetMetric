{
  "name": "netmetric",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22.15.0 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "restart": "pnpm dev:clean && pnpm frontend:stop:auth && pnpm dev:up && pnpm frontend:dev:auth",
    "prepare": "husky",
    "repo:validate": "node ./scripts/workspace/validate-workspace.mjs",
    "repo:format": "prettier . --write",
    "repo:format:check": "prettier . --check",
    "repo:check": "pnpm run repo:validate && pnpm peers check && pnpm run frontend:typecheck && pnpm run frontend:lint && pnpm run repo:format:check",
    "repo:check:prod": "pnpm install --frozen-lockfile && pnpm run repo:validate && pnpm peers check && pnpm run frontend:typecheck && pnpm run frontend:lint && pnpm run repo:format:check && pnpm run frontend:build",
    "frontend:lint": "turbo run lint --output-logs=errors-only",
    "frontend:typecheck": "turbo run typecheck --output-logs=errors-only",
    "frontend:build": "turbo run build --output-logs=errors-only",
    "frontend:test": "turbo run test --output-logs=errors-only",
    "frontend:coverage": "turbo run coverage --output-logs=errors-only",
    "frontend:check": "pnpm run frontend:typecheck && pnpm run frontend:lint && pnpm run frontend:build && pnpm run frontend:test",
    "frontend:health": "pnpm run health:dead-imports && pnpm run health:unused-exports && pnpm run health:circular-deps && pnpm run health:deps-consistency && pnpm run governance:validate && pnpm run contract:validate",
    "frontend:auth-web:dev": "pnpm --filter auth-web dev",
    "frontend:public-web:dev": "pnpm --filter public-web dev",
    "frontend:stop:auth": "node ./scripts/dev/kill-port.mjs 7002",
    "frontend:dev:auth": "pnpm frontend:stop:auth && pnpm --filter auth-web dev",
    "dotnet:restore": "node ./scripts/orchestration/run-dotnet-task.mjs restore",
    "dotnet:build": "node ./scripts/orchestration/run-dotnet-task.mjs build",
    "dotnet:test": "node ./scripts/orchestration/run-dotnet-task.mjs test",
    "dotnet:format": "node ./scripts/orchestration/run-dotnet-task.mjs format",
    "dotnet:check": "pnpm run dotnet:restore && pnpm run dotnet:build && pnpm run dotnet:test",
    "native:configure": "node ./scripts/orchestration/run-native-task.mjs configure",
    "native:build": "node ./scripts/orchestration/run-native-task.mjs build",
    "native:test": "node ./scripts/orchestration/run-native-task.mjs test",
    "native:check": "pnpm run native:configure && pnpm run native:build && pnpm run native:test",
    "deploy:lint": "node ./scripts/orchestration/run-deploy-task.mjs lint",
    "deploy:validate": "node ./scripts/orchestration/run-deploy-task.mjs validate",
    "deploy:check": "pnpm run deploy:lint && pnpm run deploy:validate",
    "ci:frontend": "pnpm run repo:validate && pnpm run frontend:check && pnpm run frontend:coverage",
    "ci:dotnet": "pnpm run dotnet:check",
    "ci:native": "pnpm run native:check",
    "ci:deploy": "pnpm run deploy:check",
    "ci:repo": "pnpm run repo:check",
    "health:dead-imports": "pnpm --filter @netmetric/ui lint",
    "health:unused-exports": "knip --config knip.json --include exports --no-exit-code",
    "health:circular-deps": "madge --circular --extensions ts,tsx --ts-config ./packages/frontend/ui/tsconfig.json ./packages/frontend/ui/src",
    "health:deps-consistency": "pnpm dedupe --check",
    "guard:secrets": "node ./scripts/security/scan-staged-secrets.mjs",
    "guard:gitleaks": "node ./scripts/security/run-gitleaks-if-available.mjs",
    "guard:precommit": "node ./scripts/git-hooks/pre-commit.mjs",
    "guard:prepush": "pnpm run guard:gitleaks && pnpm run repo:validate && pnpm run frontend:build",
    "contract:validate": "node ./scripts/contracts/validate-contracts.mjs",
    "governance:validate": "node ./scripts/governance/validate-ui-governance.mjs",
    "check": "pnpm run repo:check",
    "check:prod": "pnpm run repo:check:prod",
    "lint": "pnpm run frontend:lint",
    "typecheck": "pnpm run frontend:typecheck",
    "build": "pnpm run frontend:build",
    "test": "pnpm run frontend:test",
    "coverage": "pnpm run frontend:coverage",
    "workspace:validate": "pnpm run repo:validate",
    "workspace:health": "pnpm run frontend:health",
    "format:check": "pnpm run repo:format:check",
    "format:frontend": "prettier . --write",
    "format:csharp": "dotnet csharpier .",
    "format:dotnet": "dotnet format Netmetric.slnx",
    "format": "pnpm run repo:format && pnpm format:frontend && pnpm format:csharp && pnpm format:dotnet",
    "sonar:backend": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sonar-backend.ps1",
    "sonar:frontend": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sonar-frontend.ps1",
    "sonar:frontend:strict": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sonar-frontend.ps1 -StrictCoverage",
    "sonar:all": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sonar-all.ps1",
    "sonar:all:strict": "powershell -ExecutionPolicy Bypass -File .\\scripts\\sonar-all.ps1 -StrictCoverage",
    "dev:up": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev-up.ps1",
    "dev:seed:auth": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev-seed-auth.ps1",
    "dev:auth:seed": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev-auth-seed.ps1",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File .\\scripts\\dev-clean.ps1"
  },
  "workspaces": [
    "apps/*",
    "packages/frontend/*"
  ],
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.39.4",
    "@sonar/scan": "^4.3.6",
    "eslint": "^9",
    "husky": "^9.1.7",
    "knip": "^5.64.1",
    "lint-staged": "^16.2.6",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "sonarqube-scanner": "^4.3.6",
    "tailwindcss": "^4.2.4",
    "turbo": "^2.9.12",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{md,json,yml,yaml,css,ts,tsx,js,mjs,cjs}": [
      "prettier --check"
    ],
    "packages/frontend/ui/src/**/*.{ts,tsx}": [
      "pnpm --filter @netmetric/ui exec eslint --max-warnings=0"
    ]
  },
  "pnpm": {
    "overrides": {
      "typescript": "5.9.3"
    }
  }
}
