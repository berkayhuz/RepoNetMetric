{
  "name": "@netmetric/i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate:messages": "node ./scripts/generate-message-registry.mjs",
    "check:frontend-i18n": "node ./scripts/check-frontend-i18n.mjs",
    "check:i18n-quality": "node ./scripts/check-i18n-quality.mjs",
    "typecheck": "pnpm run generate:messages && tsc --noEmit",
    "build": "pnpm run typecheck && pnpm run check:i18n-quality"
  },
  "devDependencies": {
    "@netmetric/tsconfig": "workspace:*",
    "typescript": "5.9.3"
  }
}
