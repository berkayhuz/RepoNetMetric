{
  "AllowedHosts": "gateway.netmetric.net",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8080"
      },
      "Https": {
        "Url": "https://+:8443"
      }
    }
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": ""
    }
  },
  "Security": {
    "Cors": {
      "AllowedOrigins": ["https://app.netmetric.net"],
      "AllowCredentials": true
    },
    "ForwardedHeaders": {
      "ForwardLimit": 2,
      "KnownProxies": [],
      "KnownNetworks": ["10.0.0.0/8"]
    },
    "TenantForwarding": {
      "RequireTenant": true,
      "StaticTenantId": "11111111-1111-1111-1111-111111111111",
      "StaticTenantSlug": "",
      "HeaderName": "X-Tenant-Id",
      "SlugHeaderName": "X-Tenant-Slug",
      "TrustedHostSuffixes": ["netmetric.net"],
      "ReservedSubdomains": ["app", "api", "auth", "gateway", "www"]
    },
    "TrustedGateway": {
      "RequireTrustedGateway": true,
      "Source": "NetMetric.ApiGateway",
      "AllowedSources": ["NetMetric.ApiGateway"],
      "CurrentKeyId": "gateway-prod-key-2026-01",
      "Keys": [
        {
          "KeyId": "gateway-prod-key-2026-01",
          "Secret": "",
          "Enabled": true,
          "SignRequests": true
        }
      ]
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-api-route": {
        "ClusterId": "auth-api-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Metadata": {
          "TrustedGatewaySigning": "true",
          "TenantForwarding": "true"
        }
      },
      "auth-jwks-route": {
        "ClusterId": "auth-api-cluster",
        "Match": {
          "Path": "/.well-known/jwks.json"
        }
      },
      "auth-openid-configuration-route": {
        "ClusterId": "auth-api-cluster",
        "Match": {
          "Path": "/.well-known/openid-configuration"
        }
      },
      "crm-api-route": {
        "ClusterId": "crm-api-cluster",
        "Order": 100,
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "account-api-route": {
        "ClusterId": "account-api-cluster",
        "Order": 10,
        "Match": {
          "Path": "/api/v1/account/{**catch-all}"
        },
        "Metadata": {
          "TenantForwarding": "false"
        }
      },
      "crm-health-live-route": {
        "ClusterId": "crm-api-cluster",
        "Match": {
          "Path": "/crm/health/live"
        },
        "Transforms": [
          {
            "PathSet": "/health/live"
          }
        ]
      }
    },
    "Clusters": {
      "auth-api-cluster": {
        "HttpRequest": {
          "ActivityTimeout": "00:00:15",
          "Version": "2",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "HttpClient": {
          "MaxConnectionsPerServer": 256,
          "EnableMultipleHttp2Connections": true,
          "DangerousAcceptAnyServerCertificate": false
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://netmetric-auth-api:8080/"
          }
        }
      },
      "crm-api-cluster": {
        "HttpRequest": {
          "ActivityTimeout": "00:00:30",
          "Version": "2",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "HttpClient": {
          "MaxConnectionsPerServer": 256,
          "EnableMultipleHttp2Connections": true,
          "DangerousAcceptAnyServerCertificate": false
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://netmetric-crm-api:8080/"
          }
        }
      },
      "account-api-cluster": {
        "HttpRequest": {
          "ActivityTimeout": "00:00:30",
          "Version": "2",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "HttpClient": {
          "MaxConnectionsPerServer": 256,
          "EnableMultipleHttp2Connections": true,
          "DangerousAcceptAnyServerCertificate": false
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://netmetric-account-api:8080/"
          }
        }
      }
    }
  }
}
