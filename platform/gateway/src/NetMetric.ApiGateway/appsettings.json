{
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5030"
      },
      "Https": {
        "Url": "https://localhost:7025"
      }
    }
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": ""
    }
  },
  "Security": {
    "Cors": {
      "AllowedOrigins": ["https://localhost:7025", "http://localhost:5030"],
      "AllowCredentials": true
    },
    "ForwardedHeaders": {
      "ForwardLimit": 2,
      "KnownProxies": ["127.0.0.1", "::1", "192.168.1.1"],
      "KnownNetworks": []
    },
    "TenantForwarding": {
      "RequireTenant": true,
      "StaticTenantId": "11111111-1111-1111-1111-111111111111",
      "StaticTenantSlug": "",
      "HeaderName": "X-Tenant-Id",
      "SlugHeaderName": "X-Tenant-Slug",
      "TrustedHostSuffixes": ["localhost"],
      "ReservedSubdomains": ["app", "api", "auth", "gateway", "www"]
    },
    "Headers": {
      "ContentSecurityPolicy": "default-src 'none'; frame-ancestors 'none'; base-uri 'none'; object-src 'none'; form-action 'none';",
      "ReferrerPolicy": "no-referrer",
      "PermissionsPolicy": "camera=(), geolocation=(), microphone=()",
      "EnableHsts": true,
      "HstsMaxAgeSeconds": 31536000,
      "PreloadHsts": true,
      "IncludeSubDomains": true
    },
    "RateLimiting": {
      "Global": {
        "PermitLimit": 200,
        "WindowSeconds": 10,
        "QueueLimit": 0
      },
      "Proxy": {
        "PermitLimit": 120,
        "WindowSeconds": 10,
        "QueueLimit": 0
      }
    },
    "TrustedGateway": {
      "RequireTrustedGateway": true,
      "Source": "NetMetric.ApiGateway",
      "AllowedSources": ["NetMetric.ApiGateway"],
      "CurrentKeyId": "gateway-local-key-2026-01",
      "SignatureHeaderName": "X-Gateway-Signature",
      "TimestampHeaderName": "X-Gateway-Timestamp",
      "KeyIdHeaderName": "X-Gateway-Key-Id",
      "SourceHeaderName": "X-Gateway-Source",
      "NonceHeaderName": "X-Gateway-Request-Id",
      "ContentHashHeaderName": "X-Gateway-Content-SHA256",
      "AllowedClockSkewSeconds": 30,
      "ReplayProtectionWindowSeconds": 90,
      "AllowedGatewayProxies": ["127.0.0.1", "::1", "192.168.1.1"],
      "AllowedGatewayNetworks": [],
      "Keys": [
        {
          "KeyId": "gateway-local-key-2026-01",
          "Secret": "",
          "Enabled": true,
          "SignRequests": true
        }
      ]
    }
  },
  "ReverseProxy": {
    "Routes": {
      "auth-api-route": {
        "ClusterId": "auth-api-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Metadata": {
          "TrustedGatewaySigning": "true",
          "TenantForwarding": "false"
        }
      },
      "auth-jwks-route": {
        "ClusterId": "auth-api-cluster",
        "Match": {
          "Path": "/.well-known/jwks.json"
        }
      },
      "auth-openid-configuration-route": {
        "ClusterId": "auth-api-cluster",
        "Match": {
          "Path": "/.well-known/openid-configuration"
        }
      },
      "auth-health-live-route": {
        "ClusterId": "auth-api-cluster",
        "Match": {
          "Path": "/auth/health/live"
        },
        "Transforms": [
          {
            "PathSet": "/health/live"
          }
        ]
      },
      "auth-health-ready-route": {
        "ClusterId": "auth-api-cluster",
        "Match": {
          "Path": "/auth/health/ready"
        },
        "Transforms": [
          {
            "PathSet": "/health/ready"
          }
        ]
      },
      "crm-api-route": {
        "ClusterId": "crm-api-cluster",
        "Order": 100,
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "tools-api-route": {
        "ClusterId": "tools-api-cluster",
        "Order": 20,
        "Match": {
          "Path": "/api/v1/tools/{**catch-all}"
        },
        "Metadata": {
          "TenantForwarding": "false"
        }
      },
      "tools-health-live-route": {
        "ClusterId": "tools-api-cluster",
        "Match": {
          "Path": "/tools/health/live"
        },
        "Transforms": [
          {
            "PathSet": "/health/live"
          }
        ]
      },
      "tools-health-ready-route": {
        "ClusterId": "tools-api-cluster",
        "Match": {
          "Path": "/tools/health/ready"
        },
        "Transforms": [
          {
            "PathSet": "/health/ready"
          }
        ]
      },
      "account-api-route": {
        "ClusterId": "account-api-cluster",
        "Order": 10,
        "Match": {
          "Path": "/api/v1/account/{**catch-all}"
        },
        "Metadata": {
          "TenantForwarding": "false"
        }
      },
      "account-health-live-route": {
        "ClusterId": "account-api-cluster",
        "Match": {
          "Path": "/account/health/live"
        },
        "Transforms": [
          {
            "PathSet": "/health/live"
          }
        ]
      },
      "account-health-ready-route": {
        "ClusterId": "account-api-cluster",
        "Match": {
          "Path": "/account/health/ready"
        },
        "Transforms": [
          {
            "PathSet": "/health/ready"
          }
        ]
      },
      "crm-health-live-route": {
        "ClusterId": "crm-api-cluster",
        "Match": {
          "Path": "/crm/health/live"
        },
        "Transforms": [
          {
            "PathSet": "/health/live"
          }
        ]
      }
    },
    "Clusters": {
      "auth-api-cluster": {
        "HttpRequest": {
          "ActivityTimeout": "00:00:15",
          "Version": "2",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "HttpClient": {
          "MaxConnectionsPerServer": 256,
          "EnableMultipleHttp2Connections": true,
          "DangerousAcceptAnyServerCertificate": false
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5297/"
          }
        }
      },
      "crm-api-cluster": {
        "HttpRequest": {
          "ActivityTimeout": "00:00:30",
          "Version": "2",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "HttpClient": {
          "MaxConnectionsPerServer": 256,
          "EnableMultipleHttp2Connections": true,
          "DangerousAcceptAnyServerCertificate": false
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5246/"
          }
        }
      },
      "tools-api-cluster": {
        "HttpRequest": {
          "ActivityTimeout": "00:00:30",
          "Version": "2",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "HttpClient": {
          "MaxConnectionsPerServer": 256,
          "EnableMultipleHttp2Connections": true,
          "DangerousAcceptAnyServerCertificate": false
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5305/"
          }
        }
      },
      "account-api-cluster": {
        "HttpRequest": {
          "ActivityTimeout": "00:00:30",
          "Version": "2",
          "VersionPolicy": "RequestVersionOrLower"
        },
        "HttpClient": {
          "MaxConnectionsPerServer": 256,
          "EnableMultipleHttp2Connections": true,
          "DangerousAcceptAnyServerCertificate": false
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Policy": "TransportFailureRate",
            "ReactivationPeriod": "00:00:30"
          }
        },
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5301/"
          }
        }
      }
    }
  }
}
