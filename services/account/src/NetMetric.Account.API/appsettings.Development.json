{
  "Authentication": {
    "Jwt": {
      "Authority": "http://localhost:5297",
      "Issuer": "http://localhost:5297",
      "Audience": "http://localhost:5030",
      "ClockSkewSeconds": 60,
      "RequireHttpsMetadata": false
    }
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "AuthProfileBootstrap": {
    "Enabled": true
  },
  "MembershipService": {
    "BaseUrl": "https://localhost:7246",
    "AllowUnavailableFallback": true
  },
  "Media": {
    "PublicBaseUrl": "http://localhost:5301/uploads",
    "StorageProvider": "LocalFile",
    "MaxImageBytes": 10485760,
    "AllowedImageContentTypes": ["image/jpeg", "image/png", "image/webp"],
    "AllowedImageExtensions": [".jpg", ".jpeg", ".png", ".webp"],
    "Local": {
      "RootPath": ".runlogs/media",
      "RequestPath": "/uploads"
    }
  }
}
