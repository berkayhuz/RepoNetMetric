{
  "AllowedHosts": "account-api.netmetric.net;netmetric-account-api",
  "ConnectionStrings": {
    "AccountDb": ""
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8080"
      },
      "Https": {
        "Url": "https://+:8443"
      }
    }
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": ""
    }
  },
  "Authentication": {
    "Jwt": {
      "Authority": "https://auth.netmetric.net",
      "MetadataAddress": "https://auth.netmetric.net/.well-known/openid-configuration",
      "Issuer": "https://auth.netmetric.net",
      "Audience": "https://app.netmetric.net",
      "ClockSkewSeconds": 60,
      "RequireHttpsMetadata": true
    }
  },
  "Database": {
    "ApplyMigrationsOnStartup": false,
    "CommandTimeoutSeconds": 30,
    "MaxRetryCount": 5,
    "MaxRetryDelaySeconds": 10
  },
  "IdentityService": {
    "BaseUrl": "https://netmetric-auth-api:8443",
    "GetRetryCount": 2,
    "GetRetryDelayMilliseconds": 150
  },
  "MembershipService": {
    "BaseUrl": "https://netmetric-crm-api:8443",
    "TimeoutSeconds": 10,
    "AllowUnavailableFallback": false,
    "SkipRemoteCalls": false
  },
  "Security": {
    "ForwardedHeaders": {
      "ForwardLimit": 2,
      "KnownProxies": [],
      "KnownNetworks": ["10.0.0.0/8"]
    },
    "Headers": {
      "EnableHsts": true
    },
    "TrustedGateway": {
      "RequireTrustedGateway": true,
      "Source": "NetMetric.Account",
      "AllowedSources": ["NetMetric.Account"],
      "CurrentKeyId": "account-internal-prod-key-2026-01",
      "SignatureHeaderName": "X-Gateway-Signature",
      "TimestampHeaderName": "X-Gateway-Timestamp",
      "KeyIdHeaderName": "X-Gateway-Key-Id",
      "SourceHeaderName": "X-Gateway-Source",
      "NonceHeaderName": "X-Gateway-Request-Id",
      "ContentHashHeaderName": "X-Gateway-Content-SHA256",
      "AllowedClockSkewSeconds": 30,
      "ReplayProtectionWindowSeconds": 90,
      "AllowedGatewayProxies": [],
      "AllowedGatewayNetworks": [],
      "Keys": [
        {
          "KeyId": "account-internal-prod-key-2026-01",
          "Secret": "",
          "Enabled": true,
          "SignRequests": true
        }
      ]
    }
  },
  "Outbox": {
    "EnableProcessor": true,
    "PollingIntervalSeconds": 5,
    "BatchSize": 50,
    "MaxAttempts": 12,
    "PoisonDelayMinutes": 60
  },
  "AuthProfileBootstrap": {
    "Enabled": true,
    "QueueName": "netmetric.account.auth-user-registered.v1"
  },
  "Media": {
    "PublicBaseUrl": "https://cdn.netmetric.net",
    "StorageProvider": "CloudflareR2",
    "MaxImageBytes": 10485760,
    "AllowedImageContentTypes": ["image/jpeg", "image/png", "image/webp"],
    "AllowedImageExtensions": [".jpg", ".jpeg", ".png", ".webp"],
    "CloudflareR2": {
      "AccountId": "",
      "BucketName": "",
      "AccessKeyId": "",
      "SecretAccessKey": "",
      "EndpointUrl": "",
      "ObjectKeyPrefix": "netmetric",
      "UsePathStyle": true
    }
  },
  "Messaging": {
    "RabbitMq": {
      "Uri": "",
      "Exchange": "netmetric.integration",
      "NetworkRecoveryIntervalSeconds": 10,
      "ConsumerDispatchConcurrency": 4,
      "PrefetchCount": 16
    }
  }
}
