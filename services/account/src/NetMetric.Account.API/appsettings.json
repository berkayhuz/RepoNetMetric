{
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5301"
      },
      "Https": {
        "Url": "https://localhost:7241"
      }
    }
  },
  "OpenApi": {
    "Title": "NetMetric Account API",
    "Version": "v1"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false,
    "CommandTimeoutSeconds": 30,
    "MaxRetryCount": 5,
    "MaxRetryDelaySeconds": 10
  },
  "Authentication": {
    "Jwt": {
      "Authority": "",
      "MetadataAddress": null,
      "Issuer": "",
      "Audience": "",
      "ClockSkewSeconds": 60,
      "RequireHttpsMetadata": true
    }
  },
  "IdentityService": {
    "BaseUrl": "https://localhost:7223",
    "SecuritySummaryPath": "/api/v1/internal/identity/users/{userId}/security-summary",
    "ChangePasswordPath": "/api/v1/internal/identity/users/{userId}/password/change",
    "MfaStatusPath": "/api/v1/internal/identity/users/{userId}/mfa",
    "MfaSetupPath": "/api/v1/internal/identity/users/{userId}/mfa/setup",
    "MfaConfirmPath": "/api/v1/internal/identity/users/{userId}/mfa/confirm",
    "MfaDisablePath": "/api/v1/internal/identity/users/{userId}/mfa",
    "RecoveryCodesRegeneratePath": "/api/v1/internal/identity/users/{userId}/mfa/recovery-codes/regenerate",
    "EmailChangeRequestPath": "/api/v1/internal/identity/users/{userId}/email/change-request",
    "EmailChangeConfirmPath": "/api/v1/internal/identity/users/{userId}/email/change-confirm",
    "TrustedDevicesPath": "/api/v1/internal/identity/users/{userId}/trusted-devices",
    "TrustedDeviceRevokePath": "/api/v1/internal/identity/users/{userId}/trusted-devices/{deviceId}",
    "InvitationsPath": "/api/v1/internal/account-management/invitations",
    "InvitationResendPath": "/api/v1/internal/account-management/invitations/{invitationId}/resend",
    "InvitationRevokePath": "/api/v1/internal/account-management/invitations/{invitationId}/revoke",
    "MembersPath": "/api/v1/internal/account-management/members",
    "RolesCatalogPath": "/api/v1/internal/account-management/roles/catalog",
    "MemberRolesPath": "/api/v1/internal/account-management/members/{userId}/roles",
    "TimeoutSeconds": 10,
    "GetRetryCount": 2,
    "GetRetryDelayMilliseconds": 150
  },
  "MembershipService": {
    "BaseUrl": "https://localhost:7246",
    "OrganizationsPath": "/api/v1/internal/membership/users/{userId}/organizations",
    "PermissionsPath": "/api/v1/internal/membership/users/{userId}/permissions",
    "TimeoutSeconds": 10
  },
  "Audit": {
    "PersistAuditEntries": true,
    "MetadataMaxLength": 4000,
    "MaskedMetadataKeys": [
      "password",
      "token",
      "refreshToken",
      "accessToken",
      "authorization",
      "mfaSecret",
      "recoveryCode"
    ]
  },
  "Authorization": {
    "RequireTenantClaim": true,
    "RequiredPermissionClaimType": "permission",
    "RequiredTenantClaimType": "tenant_id"
  },
  "Security": {
    "ForwardedHeaders": {
      "ForwardLimit": 2,
      "KnownProxies": []
    },
    "Headers": {
      "ContentSecurityPolicy": "default-src 'none'; frame-ancestors 'none'; frame-src 'none'; base-uri 'none'; object-src 'none'; form-action 'none';",
      "ReferrerPolicy": "no-referrer",
      "PermissionsPolicy": "camera=(), geolocation=(), microphone=()",
      "EnableHsts": true,
      "HstsMaxAgeSeconds": 31536000
    },
    "RateLimiting": {
      "Global": {
        "PermitLimit": 600,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Critical": {
        "PermitLimit": 20,
        "WindowSeconds": 60,
        "QueueLimit": 0
      }
    },
    "TrustedGateway": {
      "RequireTrustedGateway": true,
      "Source": "NetMetric.Account",
      "AllowedSources": ["NetMetric.Account"],
      "CurrentKeyId": "account-internal-local-key-2026-01",
      "SignatureHeaderName": "X-Gateway-Signature",
      "TimestampHeaderName": "X-Gateway-Timestamp",
      "KeyIdHeaderName": "X-Gateway-Key-Id",
      "SourceHeaderName": "X-Gateway-Source",
      "NonceHeaderName": "X-Gateway-Request-Id",
      "ContentHashHeaderName": "X-Gateway-Content-SHA256",
      "AllowedClockSkewSeconds": 30,
      "ReplayProtectionWindowSeconds": 90,
      "AllowedGatewayProxies": [],
      "AllowedGatewayNetworks": [],
      "Keys": [
        {
          "KeyId": "account-internal-local-key-2026-01",
          "Secret": "",
          "Enabled": true,
          "SignRequests": true
        }
      ]
    }
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": ""
    }
  },
  "Outbox": {
    "EnableProcessor": true,
    "PollingIntervalSeconds": 5,
    "BatchSize": 50,
    "MaxAttempts": 12,
    "PoisonDelayMinutes": 60
  },
  "AuthProfileBootstrap": {
    "Enabled": true,
    "QueueName": "netmetric.account.auth-user-registered.v1"
  },
  "Messaging": {
    "RabbitMq": {
      "Uri": "amqp://guest:guest@localhost:5672/",
      "Exchange": "netmetric.integration",
      "NetworkRecoveryIntervalSeconds": 10,
      "ConsumerDispatchConcurrency": 4,
      "PrefetchCount": 16
    }
  }
}
