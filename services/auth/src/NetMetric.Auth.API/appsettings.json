{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "IdentityConnection": "Server=localhost;Database=CRM.AuthDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5297"
      },
      "Https": {
        "Url": "https://localhost:7223"
      }
    }
  },
  "OpenApi": {
    "Title": "CRM Auth API",
    "Version": "v1"
  },
  "OpenTelemetry": {
    "Otlp": {
      "Endpoint": ""
    }
  },
  "Messaging": {
    "RabbitMq": {
      "Uri": "amqp://guest:guest@localhost:5672/",
      "Exchange": "netmetric.integration",
      "NetworkRecoveryIntervalSeconds": 10,
      "ConsumerDispatchConcurrency": 4,
      "PrefetchCount": 16
    }
  },
  "Outbox": {
    "EnablePublisher": true,
    "PollingIntervalSeconds": 5,
    "BatchSize": 50,
    "MaxAttempts": 12,
    "LockSeconds": 60
  },
  "Security": {
    "Cors": {
      "AllowedOrigins": [
        "https://localhost:7025",
        "http://localhost:5030",
        "http://localhost:7002"
      ],
      "AllowCredentials": true
    },
    "ForwardedHeaders": {
      "ForwardLimit": 2,
      "KnownProxies": ["127.0.0.1", "::1", "192.168.1.1"],
      "KnownNetworks": []
    },
    "Headers": {
      "ContentSecurityPolicy": "default-src 'none'; frame-ancestors 'none'; frame-src 'none'; base-uri 'none'; object-src 'none'; form-action 'none';",
      "ReferrerPolicy": "no-referrer",
      "PermissionsPolicy": "camera=(), geolocation=(), microphone=()",
      "EnableHsts": true,
      "HstsMaxAgeSeconds": 31536000,
      "PreloadHsts": true,
      "IncludeSubDomains": true
    },
    "TenantResolution": {
      "RequireResolvedTenant": false,
      "AllowBodyFallback": true,
      "HeaderName": "X-Tenant-Id",
      "SlugHeaderName": "X-Tenant-Slug",
      "TrustedHostSuffixes": ["localhost"],
      "TenantOptionalPathPrefixes": ["/api/auth/register", "/api/auth/session-status"]
    },
    "TokenTransport": {
      "Mode": "CookiesOnly",
      "AllowRefreshTokenFromRequestBody": false,
      "AllowSessionIdFromRequestBody": false,
      "AccessCookieName": "__Secure-netmetric-access",
      "RefreshCookieName": "__Secure-netmetric-refresh",
      "SessionCookieName": "__Secure-netmetric-session",
      "SameSite": "Lax",
      "AccessCookiePath": "/",
      "RefreshCookiePath": "/api/auth",
      "SessionCookiePath": "/api/auth",
      "CookieDomain": null
    },
    "TrustedGateway": {
      "RequireTrustedGateway": true,
      "Source": "NetMetric.ApiGateway",
      "AllowedSources": ["NetMetric.ApiGateway", "NetMetric.Account"],
      "CurrentKeyId": "gateway-local-key-2026-01",
      "SignatureHeaderName": "X-Gateway-Signature",
      "TimestampHeaderName": "X-Gateway-Timestamp",
      "KeyIdHeaderName": "X-Gateway-Key-Id",
      "SourceHeaderName": "X-Gateway-Source",
      "NonceHeaderName": "X-Gateway-Request-Id",
      "ContentHashHeaderName": "X-Gateway-Content-SHA256",
      "AllowedClockSkewSeconds": 30,
      "ReplayProtectionWindowSeconds": 90,
      "AllowedGatewayProxies": ["127.0.0.1", "::1", "192.168.1.1"],
      "AllowedGatewayNetworks": [],
      "Keys": [
        {
          "KeyId": "gateway-local-key-2026-01",
          "Secret": "",
          "Enabled": true,
          "SignRequests": true
        },
        {
          "KeyId": "account-internal-local-key-2026-01",
          "Secret": "",
          "Enabled": true,
          "SignRequests": false
        }
      ]
    },
    "InternalIdentity": {
      "AllowedSources": ["NetMetric.Account"]
    },
    "RateLimiting": {
      "Global": {
        "PermitLimit": 120,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Login": {
        "PermitLimit": 5,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Register": {
        "PermitLimit": 3,
        "WindowSeconds": 300,
        "QueueLimit": 0
      },
      "Refresh": {
        "PermitLimit": 10,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Logout": {
        "PermitLimit": 20,
        "WindowSeconds": 60,
        "QueueLimit": 0
      },
      "Invite": {
        "PermitLimit": 10,
        "WindowSeconds": 300,
        "QueueLimit": 0
      },
      "RoleManagement": {
        "PermitLimit": 20,
        "WindowSeconds": 300,
        "QueueLimit": 0
      }
    },
    "Alerts": {
      "EnableStructuredAlerts": true
    },
    "TokenValidationCache": {
      "EnableCache": true,
      "AbsoluteExpirationSeconds": 30,
      "NegativeAbsoluteExpirationSeconds": 10,
      "KeyPrefix": "auth:user-token-state"
    }
  },
  "Jwt": {
    "Issuer": "https://localhost:7223",
    "Audience": "https://localhost:7025",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14,
    "SigningKeys": []
  },
  "IdentitySecurity": {
    "MaxFailedAccessAttempts": 5,
    "LockoutMinutes": 15,
    "AllowedPublicTenantIds": ["11111111-1111-1111-1111-111111111111"]
  },
  "AccountLifecycle": {
    "RequireConfirmedEmailForLogin": true,
    "EmailConfirmationTokenMinutes": 1440,
    "PasswordResetTokenMinutes": 30,
    "EmailChangeTokenMinutes": 30,
    "InvitationTokenMinutes": 10080,
    "TokenBytes": 32,
    "PublicAppBaseUrl": "https://localhost:7146",
    "ConfirmEmailPath": "/confirm-email",
    "ResetPasswordPath": "/reset-password",
    "ConfirmEmailChangePath": "/confirm-email-change"
  },
  "InvitationDelivery": {
    "AcceptBaseUrl": "https://localhost:7146",
    "AcceptPath": "/invite/accept",
    "SenderName": "NetMetric",
    "SenderAddress": "no-reply@netmetric.local",
    "DisableDelivery": false,
    "Provider": "notification",
    "SmtpHost": null,
    "SmtpPort": 587,
    "SmtpUseStartTls": true,
    "SmtpUserName": null,
    "SmtpPassword": null,
    "ResendThrottleSeconds": 60,
    "MaxResends": 5
  },
  "PasswordPolicy": {
    "MinimumLength": 12,
    "MaxLength": 128,
    "RequiredUniqueChars": 4,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireNonAlphanumeric": true,
    "DisallowWhitespace": true,
    "BlacklistedPasswords": ["Password123!", "Qwerty123!", "Admin123!", "12345678"]
  },
  "Seed": {
    "DefaultTenantId": "11111111-1111-1111-1111-111111111111",
    "AllowStartupSeed": true,
    "AllowProductionStartupSeed": false
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Authorization": {
    "DefaultRoles": ["tenant-user"],
    "DefaultPermissions": ["session:self", "profile:self"],
    "BootstrapFirstUserAsTenantOwner": true,
    "BootstrapFirstUserRoles": ["tenant-owner", "tenant-admin", "tenant-user"],
    "BootstrapFirstUserPermissions": ["*"],
    "Policies": [
      {
        "Name": "session:self",
        "RequiredPermissions": ["session:self"],
        "RequiredRoles": [],
        "RequireAuthenticatedUser": true,
        "RequireTenantClaim": true
      },
      {
        "Name": "tenant.users.invite",
        "RequiredPermissions": ["tenant.users.invite"],
        "RequiredRoles": [],
        "RequireAuthenticatedUser": true,
        "RequireTenantClaim": true
      },
      {
        "Name": "tenant.roles.read",
        "RequiredPermissions": ["roles.read"],
        "RequiredRoles": [],
        "RequireAuthenticatedUser": true,
        "RequireTenantClaim": true
      },
      {
        "Name": "tenant.roles.manage",
        "RequiredPermissions": ["roles.manage"],
        "RequiredRoles": [],
        "RequireAuthenticatedUser": true,
        "RequireTenantClaim": true
      }
    ]
  },
  "SessionSecurity": {
    "MaxActiveSessions": 5,
    "IdleTimeoutMinutes": 1440,
    "AbsoluteLifetimeDays": 14
  },
  "DataRetention": {
    "EnableCleanupService": true,
    "CleanupIntervalMinutes": 60,
    "AuditRetentionDays": 90,
    "RevokedSessionRetentionDays": 30
  },
  "Infrastructure": {
    "DistributedCache": {
      "Provider": "Memory",
      "RedisConnectionString": null,
      "InstanceName": "NetMetric:Auth:",
      "ConnectTimeoutMilliseconds": 5000,
      "AsyncTimeoutMilliseconds": 5000,
      "SyncTimeoutMilliseconds": 5000,
      "ConnectRetry": 3,
      "AbortOnConnectFail": false,
      "RequireExternalProviderInProduction": true
    },
    "DataProtection": {
      "ApplicationName": "NetMetric.Auth",
      "KeyRingPath": null,
      "RequirePersistentKeyRingInProduction": false
    }
  }
}
