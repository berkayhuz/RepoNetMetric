{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=NetMetricCrm;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True",
    "CustomerManagementConnection": "Server=localhost;Database=CRM.CustomerManagementDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True",
    "LeadManagementConnection": "Server=localhost;Database=NetMetricCrmLeadManagement;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True",
    "OpportunityManagementConnection": "Server=localhost;Database=NetMetricCrmOpportunityManagement;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True",
    "PipelineManagementConnection": "Server=localhost;Database=NetMetricCrmPipelineManagement;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True",
    "ProductCatalogConnection": "Server=localhost;Database=NetMetricCrmProductCatalog;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True",
    "DocumentManagementConnection": "Server=localhost;Database=NetMetricCrmDocumentManagement;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True",
    "QuoteManagementConnection": "Server=localhost;Database=NetMetricCrmQuoteManagement;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True",
    "TicketManagementConnection": "Server=localhost;Database=NetMetricCrmTicketManagement;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True",
    "TicketSlaManagementConnection": "Server=localhost;Database=NetMetricCrmTicketSlaManagement;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "https://localhost:7223",
      "Audience": "https://localhost:7025",
      "Authority": "https://localhost:7223",
      "MetadataAddress": "https://localhost:7223/.well-known/openid-configuration"
    }
  },
  "Security": {
    "CustomerDataSecurity": {
      "MaskSensitiveFields": true,
      "RequireTenantIsolation": true
    }
  },
  "Messaging": {
    "RabbitMq": {
      "Uri": "amqp://guest:guest@localhost:5672/",
      "Exchange": "netmetric.integration",
      "NetworkRecoveryIntervalSeconds": 10,
      "ConsumerDispatchConcurrency": 4,
      "PrefetchCount": 16
    }
  },
  "RateLimiting": {
    "PermitLimit": 600,
    "PublicCapture": {
      "PermitLimit": 20,
      "WindowSeconds": 60
    },
    "MarketingConsent": {
      "PermitLimit": 30,
      "WindowSeconds": 300
    },
    "Webhooks": {
      "PermitLimit": 120,
      "WindowSeconds": 60
    }
  },
  "Crm": {
    "PublicCapture": {
      "AllowedOrigins": [],
      "CaptchaRequired": false
    },
    "MarketingAutomation": {
      "ConsentTokens": {
        "SigningKey": "",
        "LifetimeMinutes": 10080
      }
    },
    "IntegrationProviders": {
      "WhatsApp": {
        "OutboundEnabled": false,
        "ExternalValidationEnabled": false,
        "GraphApiBaseUrl": "https://graph.facebook.com",
        "GraphApiVersion": "v23.0",
        "TimeoutSeconds": 10
      }
    }
  },
  "CustomerManagement": {
    "Outbox": {
      "Enabled": true,
      "BatchSize": 50,
      "PollIntervalSeconds": 5,
      "LeaseSeconds": 30,
      "MaxRetryCount": 8,
      "MaxBackoffSeconds": 300
    }
  }
}
