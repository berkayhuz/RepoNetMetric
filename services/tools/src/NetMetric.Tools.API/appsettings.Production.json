{
  "AllowedHosts": "tools.netmetric.net;netmetric-tools-api",
  "ConnectionStrings": {
    "ToolsDb": ""
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:8080"
      },
      "Https": {
        "Url": "https://+:8443"
      }
    }
  },
  "Tools": {
    "Authorization": {
      "RequireAuthenticatedUserForHistory": true
    },
    "RateLimiting": {
      "PublicCatalogPermitLimit": 60,
      "PublicCatalogWindowSeconds": 60
    },
    "UploadSecurity": {
      "MaxUploadBytes": 10485760,
      "MaxImageWidth": 8192,
      "MaxImageHeight": 8192,
      "MaxPdfPages": 200,
      "AllowNoOpScannerInProduction": false
    },
    "ArtifactStorage": {
      "Provider": "ObjectStorage",
      "RootPath": "/var/lib/netmetric/tools-artifacts",
      "AllowUnsafeLocalInProduction": false
    },
    "Retention": {
      "ArtifactRetentionDays": 30,
      "CleanupIntervalMinutes": 15,
      "HardDeleteAfterSoftDeleteDays": 7
    }
  }
}
