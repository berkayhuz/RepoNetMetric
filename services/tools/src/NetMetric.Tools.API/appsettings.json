{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "ToolsDb": "Server=localhost;Database=NetMetricTools;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Tools": {
    "Authorization": {
      "RequireAuthenticatedUserForHistory": true
    },
    "RateLimiting": {
      "PublicCatalogPermitLimit": 100,
      "PublicCatalogWindowSeconds": 60
    },
    "UploadSecurity": {
      "MaxUploadBytes": 10485760,
      "MaxImageWidth": 8192,
      "MaxImageHeight": 8192,
      "MaxPdfPages": 200,
      "AllowNoOpScannerInProduction": false
    },
    "ArtifactStorage": {
      "Provider": "Local",
      "RootPath": ".local/tools-artifacts",
      "AllowUnsafeLocalInProduction": false
    },
    "Retention": {
      "ArtifactRetentionDays": 30,
      "CleanupIntervalMinutes": 30,
      "HardDeleteAfterSoftDeleteDays": 7
    }
  }
}
