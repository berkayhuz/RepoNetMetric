{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build", "typecheck"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "coverage": {
      "dependsOn": ["test", "^coverage"],
      "outputs": ["coverage/**"]
    },
    "@netmetric/ui#build": {
      "outputs": []
    },
    "@netmetric/config#build": {
      "outputs": []
    },
    "@netmetric/types#build": {
      "outputs": []
    }
  }
}
